File Format Version 1.0

1 = 500 (1:3.2 1:4.1)             501 10   // Sensor: DistanceLeftCurb
2 = 500 (1:3.1 1:4.2)             502 10   // Sensor: DistanceRightCurb
3 = 1   (1:5.1)                   -   0     // ALU:    Deviation = DistanceRightCurb - DistanceLeftCurb
4 = 1   (1:5.2)                   +   0     // ALU:    LaneWidth = DistanceLeftCurb + DistanceRightCurb
5 = 1   (1:6.1)                   /   0     // ALU:    Steering  = Deviation / LaneWidth
6 = 14  (1:7.1)                   2         // Offset: Add offset to achieve 1..3 range (this allows to detect and ignore 0 output as invalid)
7 = 600                           301       // Actor:  Set Steering Actor